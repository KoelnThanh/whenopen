<?xml version="1.0" encoding="utf-8"?>
<!-- Eine Ortszeile: Status-Punkt, Name, Statustext (z.B. "bis 12:00") -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_row"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <ImageView
        android:id="@+id/row_dot"
        android:layout_width="11dp"
        android:layout_height="11dp"
        android:src="@drawable/widget_dot_open"
        android:contentDescription="@null" />

    <TextView
        android:id="@+id/row_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="11dp"
        android:textSize="14sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="@color/widget_ink" />

    <TextView
        android:id="@+id/row_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textSize="12.5sp"
        android:textStyle="bold"
        android:textColor="@color/widget_open" />
</LinearLayout>
